# =============================================================================
# Backend — kopyalayın: cp .env.example .env  (veya Windows’ta elle kopyala)
# .env dosyasını repoya commit ETMEYİN.
# =============================================================================

# --- Database (zorunlu) ---
# PostgreSQL örneği (driver: psycopg2):
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/postgres
#
# Neon: Dashboard’dan kopyalanan URL bazen postgres:// veya postgresql:// olur;
# backend otomatik olarak postgresql+psycopg2:// normalize eder.
# SSL için Neon genelde ?sslmode=require ekler; eklemekte fayda var:
# DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
#
# Yerel denemede SQLite (testlerde de kullanılır) — yalnızca geliştirme.

# --- CORS (virgülle ayrılmış origin listesi; boşsa varsayılan localhost:5173) ---
# Örnek production + Vite:
# CORS_ORIGINS=http://localhost:5173,https://my-app.vercel.app
CORS_ORIGINS=http://localhost:5173

# --- LLM (portföy demosu için anahtarsız) ---
LLM_PROVIDER=mock

# --- OpenAI (LLM_PROVIDER=openai) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# --- Gemini (LLM_PROVIDER=gemini) ---
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# --- Ollama / OpenAI-compatible (LLM_PROVIDER=ollama; LM Studio vb.) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_API_KEY=
# OLLAMA_MODEL=llama3
